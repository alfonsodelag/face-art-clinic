---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import Contact from "@/sections/Contact.astro";
import { services } from "@/content/services";
---

<BaseLayout title="Tratamientos dermatológicos | Clínica Dermatológica Demo" description="Servicios de dermatología clínica y estética: acné, manchas, rejuvenecimiento, botox, rellenos, láser y cuidado integral de la piel.">
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="Tratamientos"
        title="Una oferta clara, editable y enfocada en agendar consultas."
        intro="Los servicios se administran desde src/content/services.ts para adaptar el sitio a cada clínica sin tocar las páginas."
        align="center"
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <article class="card overflow-hidden">
            <img class="h-52 w-full object-cover" src={service.image} alt={service.title} loading="lazy" />
            <div class="p-6">
              <h2 class="font-display text-2xl font-semibold text-ink">{service.title}</h2>
              <p class="mt-3 text-sm leading-6 text-cocoa">{service.description}</p>
              <a class="mt-5 inline-flex text-sm font-semibold text-sage hover:text-ink" href="/contact">Consultar disponibilidad</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  <Contact />
</BaseLayout>
