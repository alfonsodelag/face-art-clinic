---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import Contact from "@/sections/Contact.astro";
import { posts } from "@/content/blog";
---

<BaseLayout title="Blog dermatológico | Consejos de piel y estética" description="Artículos educativos sobre cuidado de piel, acné, manchas, rejuvenecimiento y dermatología estética.">
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="Blog"
        title="Contenido local para educar, posicionar y preparar al paciente."
        intro="Por ahora el blog vive en archivos locales. Sanity queda como paso opcional si el cliente necesita editar publicaciones desde un panel."
        align="center"
      />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <article class="card overflow-hidden">
            <img class="h-56 w-full object-cover" src={post.image} alt={post.title} loading="lazy" />
            <div class="p-6">
              <time class="text-xs font-semibold uppercase tracking-[0.14em] text-sage" datetime={post.date}>{post.date}</time>
              <h2 class="mt-3 font-display text-2xl font-semibold text-ink">{post.title}</h2>
              <p class="mt-3 text-sm leading-6 text-cocoa">{post.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  <Contact />
</BaseLayout>
