---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import Contact from "@/sections/Contact.astro";
import { getBlogPosts } from "@/lib/sanity";

const posts = await getBlogPosts();
---

<BaseLayout title="Blog estetico | Art Clinic Panama" description="Articulos educativos sobre cuidado de piel, medicina estetica, armonizacion facial y tratamientos faciales en Panama.">
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="Blog"
        title="Contenido local para educar, posicionar y preparar al paciente."
        intro="Articulos educativos de Art Clinic Panama, conectados a Sanity y con respaldo local para mantener el sitio publicado."
        align="center"
      />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <article class="card overflow-hidden">
            <a href={`/blog/${post.slug}`} aria-label={`Leer ${post.title}`}>
              <img class="h-56 w-full object-cover" src={post.image} alt={post.imageAlt} loading="lazy" />
            </a>
            <div class="p-6">
              <time class="text-xs font-semibold uppercase tracking-[0.14em] text-sage" datetime={post.date}>{post.date}</time>
              <h2 class="mt-3 font-display text-2xl font-semibold text-ink">
                <a class="transition hover:text-sage" href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="mt-3 text-sm leading-6 text-cocoa">{post.excerpt}</p>
              <div class="mt-5 flex items-center justify-between gap-3 text-sm">
                <span class="text-cocoa/70">{post.readingTime}</span>
                <a class="font-semibold text-sage transition hover:text-ink" href={`/blog/${post.slug}`}>Leer articulo</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  <Contact />
</BaseLayout>
