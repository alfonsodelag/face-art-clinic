---
import Button from "@/components/Button.astro";
---

<!-- TODO: Replace /images/hero-bg.jpg with a premium Face Art Clinic facial/treatment image. -->
<section class="relative overflow-hidden bg-shell">
  <!-- Warm cream right panel (desktop) -->
  <div class="absolute inset-y-0 right-0 hidden w-[46%] bg-cream lg:block" aria-hidden="true"></div>

  <!-- Decorative gold line top-left -->
  <div class="absolute left-0 top-0 h-1 w-24 bg-sage" aria-hidden="true"></div>

  <div class="container-page relative grid min-h-[calc(100vh-5rem)] items-center gap-10 py-16 lg:grid-cols-[1fr_1fr] lg:py-24">
    <!-- Text content -->
    <div class="max-w-xl">
      <p class="eyebrow">Face Art Clinic Panamá</p>

      <h1 class="mt-5 font-display text-5xl font-semibold leading-[1.1] text-ink sm:text-6xl lg:text-[3.75rem]">
        Belleza facial con<br />
        <em class="not-italic text-sage">armonía</em>,<br />
        precisión y naturalidad.
      </h1>

      <p class="mt-6 text-lg leading-8 text-cocoa">
        Tratamientos estéticos personalizados para realzar tus rasgos, cuidar tu piel y ayudarte a verte fresca, segura y natural.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href="/contact" label="Agendar evaluación" />
        <Button href="/services" label="Ver tratamientos" variant="secondary" />
      </div>

      <!-- Trust badges -->
      <div class="mt-10 flex flex-wrap items-center gap-6 border-t border-borderSoft pt-8">
        <div class="flex items-center gap-2 text-sm text-cocoa">
          <span class="gold-line w-6"></span>
          Evaluación personalizada
        </div>
        <div class="flex items-center gap-2 text-sm text-cocoa">
          <span class="gold-line w-6"></span>
          Resultados naturales
        </div>
        <div class="flex items-center gap-2 text-sm text-cocoa">
          <span class="gold-line w-6"></span>
          Armonía facial
        </div>
      </div>
    </div>

    <!-- Image -->
    <div class="relative">
      <!-- TODO: Replace with premium Face Art Clinic facial photography (soft light, warm tones, editorial crop). -->
      <img
        class="h-[38rem] w-full rounded-3xl object-cover shadow-soft"
        src="/images/hero-bg.jpg"
        alt="Tratamiento estético facial en Face Art Clinic Panamá"
        loading="eager"
      />

      <!-- Floating trust card -->
      <div class="absolute bottom-6 left-6 max-w-xs rounded-2xl bg-ivory/95 p-5 shadow-soft backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-sage">
          Agenda tu evaluación
        </p>
        <p class="mt-2 text-sm leading-6 text-cocoa">
          Cada rostro es único. Comienza con una consulta personalizada para descubrir qué tratamiento es ideal para ti.
        </p>
        <a
          href="/contact"
          class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-sage transition hover:text-ink"
        >
          Solicitar cita
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
