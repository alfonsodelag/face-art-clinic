---
import SectionTitle from "@/components/SectionTitle.astro";
import { siteConfig } from "@/config/site";
---

<section class="section-pad bg-cream">
  <div class="container-page grid items-center gap-10 lg:grid-cols-2">
    <div class="h-96 overflow-hidden rounded-lg bg-white shadow-soft">
      <img class="h-full w-full object-cover" src="/images/breadcrumb-bg.jpg" alt={`Zona cercana a ${siteConfig.address}`} loading="lazy" />
    </div>
    <div>
      <SectionTitle
        eyebrow="Ubicación"
        title="Lista para posicionamiento local y adaptación por ciudad."
        intro="Cambia dirección, teléfono, horarios y textos SEO desde la configuración central del sitio."
      />
      <div class="mt-8 rounded-lg border border-ink/10 bg-white p-6">
        <p class="font-semibold text-ink">{siteConfig.address}</p>
        <p class="mt-2 text-sm leading-6 text-cocoa">{siteConfig.hours.weekdays}</p>
        <p class="text-sm leading-6 text-cocoa">{siteConfig.hours.saturday}</p>
      </div>
    </div>
  </div>
</section>
