---
import SectionTitle from "@/components/SectionTitle.astro";
import { faqs } from "@/content/faqs";
---

<section class="section-pad bg-cream">
  <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
    <SectionTitle
      eyebrow="Preguntas"
      title="Respuestas claras antes de la primera consulta."
      intro="Una sección útil para SEO local y para reducir fricción en pacientes que aún están comparando opciones."
    />
    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="rounded-lg border border-ink/10 bg-white p-5 shadow-sm">
          <summary class="cursor-pointer font-semibold text-ink">{faq.question}</summary>
          <p class="mt-3 text-sm leading-6 text-cocoa">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
