---
import SectionTitle from "@/components/SectionTitle.astro";
import { faqs } from "@/content/faqs";
---

<section class="section-pad bg-shell">
  <div class="container-page grid gap-12 lg:grid-cols-[0.75fr_1.25fr]">
    <div class="lg:sticky lg:top-28 lg:self-start">
      <SectionTitle
        eyebrow="Preguntas frecuentes"
        title="Respuestas claras antes de tu primera consulta."
        intro="Resolvemos las dudas más comunes para que llegues con confianza y claridad."
      />
      <a
        href="/contact"
        class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-sage transition hover:text-ink"
      >
        ¿Tienes otra pregunta? Escríbenos
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="group rounded-2xl border border-borderSoft bg-ivory p-5 shadow-card open:border-sage/30">
          <summary class="flex cursor-pointer items-start justify-between gap-4 font-semibold text-ink">
            <span>{faq.question}</span>
            <svg
              class="mt-0.5 size-4 shrink-0 text-sage transition group-open:rotate-45"
              viewBox="0 0 16 16" fill="none" aria-hidden="true"
            >
              <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </summary>
          <p class="mt-4 text-sm leading-7 text-cocoa">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
