---
import SectionTitle from "@/components/SectionTitle.astro";
import { doctors } from "@/content/doctors";
---

<section class="section-pad bg-shell">
  <div class="container-page">
    <SectionTitle
      eyebrow="Equipo"
      title="Especialistas que transmiten criterio, calma y confianza."
      intro="Perfiles editables para adaptar experiencia, fotografías y subespecialidades de cada clínica."
      align="center"
    />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {doctors.map((doctor) => (
        <article class="rounded-lg bg-white p-4 shadow-soft">
          <img class="aspect-[4/5] w-full rounded-md object-cover" src={doctor.image} alt={doctor.name} loading="lazy" />
          <div class="p-3">
            <h3 class="font-display text-2xl font-semibold text-ink">{doctor.name}</h3>
            <p class="mt-1 text-sm font-semibold text-sage">{doctor.role}</p>
            <p class="mt-3 text-sm leading-6 text-cocoa">{doctor.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
