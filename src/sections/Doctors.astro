---
import SectionTitle from "@/components/SectionTitle.astro";
import { doctors } from "@/content/doctors";
---

<!-- TODO: Replace placeholder team info with confirmed Face Art Clinic specialist data. -->
<section class="section-pad bg-cream">
  <div class="container-page">
    <SectionTitle
      eyebrow="Equipo"
      title="Especialistas con enfoque en belleza natural y armonía facial."
      intro="Cada tratamiento en Face Art Clinic es realizado por profesionales orientados a resultados personalizados, naturales y seguros."
      align="center"
    />

    <div class="mt-10 grid gap-6 justify-center md:grid-cols-2 max-w-3xl mx-auto">
      {doctors.map((doctor) => (
        <article class="card flex gap-4 p-5">
          <!-- TODO: Replace with real team photos. -->
          <img
            class="size-20 shrink-0 rounded-2xl object-cover"
            src={doctor.image}
            alt={doctor.name}
            loading="lazy"
          />
          <div>
            <h3 class="font-display text-base font-semibold text-ink">{doctor.name}</h3>
            <p class="mt-0.5 text-xs font-semibold uppercase tracking-[0.12em] text-sage">{doctor.role}</p>
            <p class="mt-2 text-sm leading-6 text-cocoa">{doctor.bio}</p>
          </div>
        </article>
      ))}
    </div>

    <p class="mt-8 text-center text-xs text-cocoa/60">
      Información del equipo pendiente de confirmación por la clínica.
    </p>
  </div>
</section>
